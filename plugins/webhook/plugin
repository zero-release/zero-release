#!/usr/bin/env bash
set -euo pipefail

hook="${1-}"
root="${ZERO_RELEASE_ROOT_DIR:?ZERO_RELEASE_ROOT_DIR is required}"

. "$root/lib/json.sh"

case "$hook" in
  doctor)
    if ! command -v curl >/dev/null 2>&1; then
      printf 'webhook: curl is required when the webhook plugin is enabled\n' >&2
      exit 1
    fi
    if [ -z "${ZERO_RELEASE_WEBHOOK_URL:-}" ]; then
      printf 'webhook: ZERO_RELEASE_WEBHOOK_URL is not set\n' >&2
      exit 1
    fi
    ;;
  verify)
    if [ "${ZERO_RELEASE_DRY_RUN:-false}" = "true" ]; then
      exit 0
    fi
    if [ "${ZERO_RELEASE_RELEASED:-false}" != "true" ]; then
      exit 0
    fi
    if ! command -v curl >/dev/null 2>&1; then
      printf 'webhook: curl is required when the webhook plugin is enabled\n' >&2
      exit 1
    fi
    if [ -z "${ZERO_RELEASE_WEBHOOK_URL:-}" ]; then
      printf 'webhook: ZERO_RELEASE_WEBHOOK_URL is required when the webhook plugin is enabled\n' >&2
      exit 1
    fi
    ;;
  notify)
    if [ "${ZERO_RELEASE_DRY_RUN:-false}" = "true" ]; then
      exit 0
    fi
    if [ "${ZERO_RELEASE_RELEASED:-false}" != "true" ]; then
      exit 0
    fi
    payload="$(printf '{"tool":"zero-release","released":true,"version":%s,"tag":%s,"previousVersion":%s,"previousTag":%s,"bump":%s,"channel":%s,"branch":%s,"compareUrl":%s}' \
      "$(zr_json_string "${ZERO_RELEASE_NEXT_VERSION:-}")" \
      "$(zr_json_string "${ZERO_RELEASE_NEXT_TAG:-}")" \
      "$(zr_json_string "${ZERO_RELEASE_PREVIOUS_VERSION:-}")" \
      "$(zr_json_string "${ZERO_RELEASE_PREVIOUS_TAG:-}")" \
      "$(zr_json_string "${ZERO_RELEASE_BUMP:-}")" \
      "$(zr_json_string "${ZERO_RELEASE_CHANNEL:-}")" \
      "$(zr_json_string "${ZERO_RELEASE_CURRENT_BRANCH:-}")" \
      "$(zr_json_string "${ZERO_RELEASE_COMPARE_URL:-}")")"
    curl -sS -X POST -H 'Content-type: application/json' --data "$payload" "$ZERO_RELEASE_WEBHOOK_URL" >/dev/null
    ;;
  analyze|verify-release|generate-notes|prepare|publish|success|fail)
    exit 0
    ;;
  *)
    printf 'webhook: unknown hook: %s\n' "$hook" >&2
    exit 1
    ;;
esac
