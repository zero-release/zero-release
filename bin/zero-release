#!/usr/bin/env bash
set -euo pipefail

script_path="${BASH_SOURCE[0]}"
case "$script_path" in
  */*) script_dir="${script_path%/*}" ;;
  *) script_dir="." ;;
esac
ZERO_RELEASE_ROOT_DIR="$(cd "$script_dir/.." && pwd)"

. "$ZERO_RELEASE_ROOT_DIR/lib/json.sh"
. "$ZERO_RELEASE_ROOT_DIR/lib/semver.sh"
. "$ZERO_RELEASE_ROOT_DIR/lib/url.sh"
. "$ZERO_RELEASE_ROOT_DIR/lib/commits.sh"

ZR_COMMAND="release"
ZR_DRY_RUN="${ZERO_RELEASE_DRY_RUN:-false}"
ZR_JSON="false"
ZR_DEBUG="${ZERO_RELEASE_DEBUG:-false}"
ZR_NO_PUSH="${ZERO_RELEASE_NO_PUSH:-false}"
ZR_NO_TAG="${ZERO_RELEASE_NO_TAG:-false}"
ZR_BRANCHES="${ZERO_RELEASE_BRANCHES:-main,master}"
ZR_PRERELEASE_BRANCHES="${ZERO_RELEASE_PRERELEASE_BRANCHES:-}"
ZR_PLUGINS="${ZERO_RELEASE_PLUGINS:-release-notes}"
ZR_TAG_FORMAT="${ZERO_RELEASE_TAG_FORMAT:-v%s}"
ZR_CHANGELOG_FILE="${ZERO_RELEASE_CHANGELOG_FILE:-CHANGELOG.md}"
ZR_PACKAGE_JSON="${ZERO_RELEASE_PACKAGE_JSON:-package.json}"
ZR_GITHUB_PR_SAFETY="false"
ZR_REASON=""
ZR_PLUGINS_VALID="true"
ZR_DOCTOR_NETWORK_OK="true"
ZR_DOCTOR_NETWORK_DETAIL="ok"

ZR_CURRENT_BRANCH=""
ZR_BRANCH_KIND=""
ZR_CHANNEL=""
ZR_PREVIOUS_VERSION="0.0.0"
ZR_PREVIOUS_TAG=""
ZR_NEXT_VERSION=""
ZR_NEXT_TAG=""
ZR_BUMP=""
ZR_RELEASED="false"
ZR_REPOSITORY_URL=""
ZR_PROVIDER="unknown"
ZR_COMPARE_URL=""
ZR_NOTES_FILE=""
ZR_RELEASE_COMMIT_CREATED="false"

ZR_PLUGIN_LIST=()
ZR_STABLE_BRANCH_LIST=()
ZR_PRERELEASE_BRANCH_LIST=()
ZR_PRERELEASE_CHANNEL_LIST=()

zr_log() {
  printf '%s\n' "$*" >&2
}

zr_debug() {
  if [ "$ZR_DEBUG" = "true" ]; then
    printf 'DEBUG: %s\n' "$*" >&2
  fi
}

zr_usage() {
  cat <<'EOF'
Usage:
  zero-release [options]
  zero-release analyze [options]
  zero-release doctor [options]

Options:
  --dry-run
  --json
  --debug
  --no-push
  --no-tag
  --branches main,master
  --plugins release-notes,changelog,package-json
  --tag-format "v%s"
  --changelog-file CHANGELOG.md
  --package-json package.json
  --prerelease-branches alpha,beta,rc
  --prerelease-branch next:beta
EOF
}

zr_trim() {
  local value="$1"
  value="${value#"${value%%[![:space:]]*}"}"
  value="${value%"${value##*[![:space:]]}"}"
  printf '%s\n' "$value"
}

zr_split_csv() {
  local csv="$1"
  local -n out_ref="$2"
  local old_ifs item

  out_ref=()
  old_ifs="$IFS"
  IFS=','
  read -r -a out_ref <<EOF
$csv
EOF
  IFS="$old_ifs"

  local cleaned=()
  for item in "${out_ref[@]}"; do
    item="$(zr_trim "$item")"
    if [ -n "$item" ]; then
      cleaned+=("$item")
    fi
  done
  out_ref=("${cleaned[@]}")
}

zr_parse_prerelease_branches() {
  local entries=()
  local entry branch channel

  zr_split_csv "$ZR_PRERELEASE_BRANCHES" entries
  ZR_PRERELEASE_BRANCH_LIST=()
  ZR_PRERELEASE_CHANNEL_LIST=()

  for entry in "${entries[@]}"; do
    branch="$entry"
    channel="$entry"
    case "$entry" in
      *:*)
        branch="${entry%%:*}"
        channel="${entry#*:}"
        ;;
    esac
    branch="$(zr_trim "$branch")"
    channel="$(zr_trim "$channel")"
    if [ -n "$branch" ] && [ -n "$channel" ]; then
      ZR_PRERELEASE_BRANCH_LIST+=("$branch")
      ZR_PRERELEASE_CHANNEL_LIST+=("$channel")
    fi
  done
}

zr_validate_branch_name() {
  local branch="$1"
  [ -n "$branch" ] || return 1
  case "$branch" in
    -*|*' '*|*$'\n'*|*$'\t'*|*'..'*|*'~'*|*'^'*|*':'*|*'?'*|*'['*|*'\\'*)
      return 1
      ;;
  esac
  [[ "$branch" =~ ^[A-Za-z0-9._/-]+$ ]]
}

zr_validate_plugin_name() {
  [[ "${1-}" =~ ^[a-z0-9][a-z0-9-]*$ ]]
}

zr_plugin_supports_hook() {
  local plugin="$1"
  local hook="$2"

  case "$plugin:$hook" in
    release-notes:generate-notes) return 0 ;;
    changelog:prepare) return 0 ;;
    package-json:verify|package-json:prepare) return 0 ;;
    git-commit:prepare) return 0 ;;
    slack:verify|slack:notify) return 0 ;;
    webhook:verify|webhook:notify) return 0 ;;
    gchat:verify|gchat:notify) return 0 ;;
    *) return 1 ;;
  esac
}

zr_plugin_is_network() {
  case "${1-}" in
    slack|webhook|gchat) return 0 ;;
    *) return 1 ;;
  esac
}

zr_plugin_enabled() {
  local wanted="$1"
  local plugin
  for plugin in "${ZR_PLUGIN_LIST[@]}"; do
    if [ "$plugin" = "$wanted" ]; then
      return 0
    fi
  done
  return 1
}

zr_hook_order() {
  case "$1" in
    verify)
      printf '%s\n' release-notes changelog package-json git-commit webhook slack gchat
      ;;
    generate-notes)
      printf '%s\n' release-notes
      ;;
    prepare)
      printf '%s\n' changelog package-json git-commit
      ;;
    notify)
      printf '%s\n' webhook slack gchat
      ;;
    *)
      printf '%s\n' release-notes changelog package-json git-commit webhook slack gchat
      ;;
  esac
}

zr_hook_plugins() {
  local hook="$1"
  local plugin
  local result=()

  while IFS= read -r plugin; do
    [ -n "$plugin" ] || continue
    if ! zr_plugin_enabled "$plugin"; then
      continue
    fi
    if [ "$ZR_DRY_RUN" = "true" ] && zr_plugin_is_network "$plugin"; then
      continue
    fi
    if zr_plugin_supports_hook "$plugin" "$hook"; then
      result+=("$plugin")
    fi
  done < <(zr_hook_order "$hook")

  printf '%s\n' "${result[@]}"
}

zr_run_hook() {
  local hook="$1"
  local plugin path

  while IFS= read -r plugin; do
    [ -n "$plugin" ] || continue
    if ! zr_plugin_enabled "$plugin"; then
      continue
    fi
    if [ "$ZR_DRY_RUN" = "true" ] && zr_plugin_is_network "$plugin"; then
      continue
    fi
    if ! zr_plugin_supports_hook "$plugin" "$hook"; then
      continue
    fi
    path="$ZERO_RELEASE_ROOT_DIR/plugins/$plugin/plugin"
    zr_debug "running $hook hook for $plugin"
    if ! "$path" "$hook"; then
      printf '%s plugin failed during %s\n' "$plugin" "$hook" >&2
      return 1
    fi
  done < <(zr_hook_order "$hook")
}

zr_plugin_array_json_for_hook() {
  local hook="$1"
  local plugins=()
  local plugin

  while IFS= read -r plugin; do
    [ -n "$plugin" ] || continue
    if ! zr_plugin_enabled "$plugin"; then
      continue
    fi
    if [ "$ZR_DRY_RUN" = "true" ] && zr_plugin_is_network "$plugin"; then
      continue
    fi
    if zr_plugin_supports_hook "$plugin" "$hook"; then
      plugins+=("$plugin")
    fi
  done < <(zr_hook_order "$hook")
  zr_json_string_array "${plugins[@]}"
}

zr_validate_plugins() {
  local plugin path

  zr_split_csv "$ZR_PLUGINS" ZR_PLUGIN_LIST
  for plugin in "${ZR_PLUGIN_LIST[@]}"; do
    if ! zr_validate_plugin_name "$plugin"; then
      printf 'Unknown or unsafe plugin name: %s\n' "$plugin" >&2
      ZR_PLUGINS_VALID="false"
      return 1
    fi
    path="$ZERO_RELEASE_ROOT_DIR/plugins/$plugin/plugin"
    if [ ! -f "$path" ]; then
      printf 'Unknown plugin: %s\n' "$plugin" >&2
      ZR_PLUGINS_VALID="false"
      return 1
    fi
  done

  ZR_PLUGINS_VALID="true"
  local old_ifs="$IFS"
  IFS=','
  ZR_PLUGINS="${ZR_PLUGIN_LIST[*]}"
  IFS="$old_ifs"
}

zr_parse_args() {
  if [ "${1-}" = "analyze" ] || [ "${1-}" = "doctor" ]; then
    ZR_COMMAND="$1"
    shift
  fi

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --dry-run)
        ZR_DRY_RUN="true"
        shift
        ;;
      --json)
        ZR_JSON="true"
        shift
        ;;
      --debug)
        ZR_DEBUG="true"
        shift
        ;;
      --no-push)
        ZR_NO_PUSH="true"
        shift
        ;;
      --no-tag)
        ZR_NO_TAG="true"
        shift
        ;;
      --branches)
        ZR_BRANCHES="${2-}"
        shift 2
        ;;
      --plugins)
        ZR_PLUGINS="${2-}"
        shift 2
        ;;
      --tag-format)
        ZR_TAG_FORMAT="${2-}"
        shift 2
        ;;
      --changelog-file)
        ZR_CHANGELOG_FILE="${2-}"
        shift 2
        ;;
      --package-json)
        ZR_PACKAGE_JSON="${2-}"
        shift 2
        ;;
      --prerelease-branches)
        ZR_PRERELEASE_BRANCHES="${2-}"
        shift 2
        ;;
      --prerelease-branch)
        if [ -n "$ZR_PRERELEASE_BRANCHES" ]; then
          ZR_PRERELEASE_BRANCHES="${ZR_PRERELEASE_BRANCHES},${2-}"
        else
          ZR_PRERELEASE_BRANCHES="${2-}"
        fi
        shift 2
        ;;
      -h|--help)
        zr_usage
        exit 0
        ;;
      *)
        printf 'Unknown option: %s\n' "$1" >&2
        zr_usage >&2
        exit 1
        ;;
    esac
  done

  if [ "${GITHUB_EVENT_NAME:-}" = "pull_request" ]; then
    ZR_DRY_RUN="true"
    ZR_GITHUB_PR_SAFETY="true"
  fi
}

zr_current_branch() {
  local branch
  branch="$(git symbolic-ref --quiet --short HEAD 2>/dev/null || git rev-parse --abbrev-ref HEAD 2>/dev/null || true)"
  if [ -z "$branch" ] || [ "$branch" = "HEAD" ]; then
    branch="${GITHUB_HEAD_REF:-${GITHUB_REF_NAME:-}}"
  fi
  printf '%s\n' "$branch"
}

zr_classify_branch() {
  local branch="$1"
  local item index

  ZR_BRANCH_KIND=""
  ZR_CHANNEL=""

  for item in "${ZR_STABLE_BRANCH_LIST[@]}"; do
    if [ "$branch" = "$item" ]; then
      ZR_BRANCH_KIND="stable"
      ZR_CHANNEL="stable"
      return 0
    fi
  done

  index=0
  for item in "${ZR_PRERELEASE_BRANCH_LIST[@]}"; do
    if [ "$branch" = "$item" ]; then
      ZR_BRANCH_KIND="prerelease"
      ZR_CHANNEL="${ZR_PRERELEASE_CHANNEL_LIST[$index]}"
      return 0
    fi
    index=$((index + 1))
  done

  return 1
}

zr_setup() {
  if ! zr_validate_tag_format "$ZR_TAG_FORMAT"; then
    printf 'Invalid tag format: %s\n' "$ZR_TAG_FORMAT" >&2
    exit 1
  fi

  zr_split_csv "$ZR_BRANCHES" ZR_STABLE_BRANCH_LIST
  zr_parse_prerelease_branches
  if [ "$ZR_COMMAND" = "doctor" ]; then
    if ! zr_validate_plugins >/dev/null 2>&1; then
      ZR_PLUGINS_VALID="false"
    fi
  else
    if ! zr_validate_plugins; then
      exit 1
    fi
  fi
}

zr_export_context() {
  export ZERO_RELEASE_ROOT_DIR
  export ZERO_RELEASE_RELEASED="$ZR_RELEASED"
  export ZERO_RELEASE_PREVIOUS_VERSION="$ZR_PREVIOUS_VERSION"
  export ZERO_RELEASE_NEXT_VERSION="$ZR_NEXT_VERSION"
  export ZERO_RELEASE_PREVIOUS_TAG="$ZR_PREVIOUS_TAG"
  export ZERO_RELEASE_NEXT_TAG="$ZR_NEXT_TAG"
  export ZERO_RELEASE_BUMP="$ZR_BUMP"
  export ZERO_RELEASE_DRY_RUN="$ZR_DRY_RUN"
  export ZERO_RELEASE_CURRENT_BRANCH="$ZR_CURRENT_BRANCH"
  export ZERO_RELEASE_CHANNEL="$ZR_CHANNEL"
  export ZERO_RELEASE_NOTES_FILE="$ZR_NOTES_FILE"
  export ZERO_RELEASE_COMPARE_URL="$ZR_COMPARE_URL"
  export ZERO_RELEASE_REPOSITORY_URL="$ZR_REPOSITORY_URL"
  export ZERO_RELEASE_CHANGELOG_FILE="$ZR_CHANGELOG_FILE"
  export ZERO_RELEASE_PACKAGE_JSON="$ZR_PACKAGE_JSON"
  export ZERO_RELEASE_PLUGINS="$ZR_PLUGINS"
  export ZERO_RELEASE_RELEASE_COMMIT_CREATED="$ZR_RELEASE_COMMIT_CREATED"
}

zr_verify_core() {
  if ! command -v git >/dev/null 2>&1; then
    printf 'git is required\n' >&2
    exit 1
  fi
  if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    printf 'zero-release must run inside a Git repository\n' >&2
    exit 1
  fi
  if [ -z "$ZR_CURRENT_BRANCH" ] || [ "$ZR_CURRENT_BRANCH" = "HEAD" ]; then
    printf 'Could not detect current branch\n' >&2
    exit 1
  fi
  if ! zr_validate_branch_name "$ZR_CURRENT_BRANCH"; then
    printf 'Unsafe branch name: %s\n' "$ZR_CURRENT_BRANCH" >&2
    exit 1
  fi
  if ! zr_classify_branch "$ZR_CURRENT_BRANCH"; then
    printf 'Branch "%s" is not allowed. Stable branches: %s. Prerelease branches: %s.\n' \
      "$ZR_CURRENT_BRANCH" "$ZR_BRANCHES" "$ZR_PRERELEASE_BRANCHES" >&2
    exit 1
  fi
  if [ "$ZR_BRANCH_KIND" = "prerelease" ] && ! zr_validate_prerelease_identifier "$ZR_CHANNEL"; then
    printf 'Invalid prerelease identifier: %s\n' "$ZR_CHANNEL" >&2
    exit 1
  fi
}

zr_analyze_release() {
  local latest prerelease_latest number base_version analysis_previous_tag
  local stable_previous_version stable_previous_tag prerelease_previous_version prerelease_previous_tag
  local prerelease_previous_base compare_result

  ZR_CURRENT_BRANCH="$(zr_current_branch)"
  zr_verify_core

  latest="$(zr_find_latest_stable_tag "$ZR_TAG_FORMAT")"
  IFS=$'\t' read -r stable_previous_version stable_previous_tag <<EOF
$latest
EOF

  ZR_PREVIOUS_VERSION="$stable_previous_version"
  ZR_PREVIOUS_TAG="$stable_previous_tag"
  analysis_previous_tag="$stable_previous_tag"

  if [ "$ZR_BRANCH_KIND" = "prerelease" ]; then
    prerelease_latest="$(zr_find_latest_prerelease_tag "$ZR_TAG_FORMAT" "$ZR_CHANNEL")"
    IFS=$'\t' read -r prerelease_previous_version prerelease_previous_tag <<EOF
$prerelease_latest
EOF
    if [ -n "$prerelease_previous_tag" ]; then
      ZR_PREVIOUS_VERSION="$prerelease_previous_version"
      ZR_PREVIOUS_TAG="$prerelease_previous_tag"
      analysis_previous_tag="$prerelease_previous_tag"
    fi
  fi

  ZR_REPOSITORY_URL="$(zr_get_repository_url 2>/dev/null || true)"
  if [ -n "$ZR_REPOSITORY_URL" ]; then
    ZR_PROVIDER="$(zr_detect_provider "$ZR_REPOSITORY_URL")"
  fi

  zr_analyze_commits "$analysis_previous_tag"
  ZR_BUMP="$ZR_ANALYSIS_BUMP"

  if [ -z "$ZR_BUMP" ]; then
    ZR_RELEASED="false"
    ZR_REASON="No release-worthy commits found"
    return 0
  fi

  base_version="$(zr_bump_version "$stable_previous_version" "$ZR_BUMP")"
  if [ "$ZR_BRANCH_KIND" = "prerelease" ]; then
    if [ -n "${prerelease_previous_version:-}" ]; then
      prerelease_previous_base="${prerelease_previous_version%%-*}"
      compare_result="$(zr_compare_stable_versions "$prerelease_previous_base" "$base_version")"
      if [ "$compare_result" = "1" ] || [ "$compare_result" = "0" ]; then
        base_version="$prerelease_previous_base"
      fi
    fi
    number="$(zr_next_prerelease_number "$ZR_TAG_FORMAT" "$base_version" "$ZR_CHANNEL")"
    ZR_NEXT_VERSION="${base_version}-${ZR_CHANNEL}.${number}"
  else
    ZR_NEXT_VERSION="$base_version"
  fi

  if ! zr_validate_semver "$ZR_NEXT_VERSION"; then
    printf 'Calculated invalid SemVer version: %s\n' "$ZR_NEXT_VERSION" >&2
    exit 1
  fi

  ZR_NEXT_TAG="$(zr_format_tag "$ZR_TAG_FORMAT" "$ZR_NEXT_VERSION")"
  if ! zr_validate_tag_name "$ZR_NEXT_TAG"; then
    printf 'Calculated invalid tag: %s\n' "$ZR_NEXT_TAG" >&2
    exit 1
  fi

  if [ -n "$ZR_PREVIOUS_TAG" ] && [ -n "$ZR_REPOSITORY_URL" ]; then
    ZR_COMPARE_URL="$(zr_compare_url "$ZR_REPOSITORY_URL" "$ZR_PREVIOUS_TAG" "$ZR_NEXT_TAG" 2>/dev/null || true)"
  else
    ZR_COMPARE_URL=""
  fi

  ZR_RELEASED="true"
  ZR_REASON=""
}

zr_generate_notes() {
  ZR_NOTES_FILE="$(mktemp)"
  zr_export_context

  if zr_plugin_enabled "release-notes"; then
    zr_run_hook "generate-notes" || return $?
  else
    zr_generate_release_notes_file "$ZR_NOTES_FILE" "$ZR_NEXT_VERSION" "$ZR_PREVIOUS_TAG" "$ZR_NEXT_TAG" "$ZR_REPOSITORY_URL" "$ZR_COMPARE_URL"
  fi
}

zr_verify_release() {
  if [ "$ZR_RELEASED" != "true" ]; then
    return 0
  fi
  if git rev-parse -q --verify "refs/tags/$ZR_NEXT_TAG" >/dev/null 2>&1; then
    printf 'Tag already exists: %s\n' "$ZR_NEXT_TAG" >&2
    exit 1
  fi
}

zr_prepare_release() {
  local before_head after_head

  if [ "$ZR_DRY_RUN" = "true" ]; then
    return 0
  fi
  before_head="$(git rev-parse HEAD)" || return $?
  zr_run_hook "prepare" || return $?
  after_head="$(git rev-parse HEAD)" || return $?
  if [ "$after_head" != "$before_head" ]; then
    ZR_RELEASE_COMMIT_CREATED="true"
  else
    ZR_RELEASE_COMMIT_CREATED="false"
  fi
  zr_export_context
}

zr_publish_release() {
  if [ "$ZR_DRY_RUN" = "true" ]; then
    return 0
  fi
  if [ "$ZR_NO_TAG" != "true" ]; then
    git tag -a "$ZR_NEXT_TAG" -F "$ZR_NOTES_FILE" || return $?
  fi
  if [ "$ZR_NO_PUSH" != "true" ]; then
    if [ "$ZR_NO_TAG" != "true" ]; then
      git push origin "$ZR_NEXT_TAG" || return $?
    fi
    if [ "$ZR_RELEASE_COMMIT_CREATED" = "true" ]; then
      git push origin "HEAD:${ZR_CURRENT_BRANCH}" || return $?
    fi
  fi
}

zr_notify_release() {
  if [ "$ZR_DRY_RUN" = "true" ]; then
    return 0
  fi
  zr_run_hook "notify" || return $?
}

zr_write_github_outputs() {
  local output_file="${GITHUB_OUTPUT:-}"
  [ -n "$output_file" ] || return 0

  {
    printf 'released=%s\n' "$ZR_RELEASED"
    printf 'version=%s\n' "$ZR_NEXT_VERSION"
    printf 'tag=%s\n' "$ZR_NEXT_TAG"
    printf 'bump=%s\n' "$ZR_BUMP"
    printf 'previous-version=%s\n' "$ZR_PREVIOUS_VERSION"
    printf 'previous-tag=%s\n' "$ZR_PREVIOUS_TAG"
    printf 'channel=%s\n' "$ZR_CHANNEL"
  } >> "$output_file"
}

zr_release_json() {
  if [ "$ZR_RELEASED" = "true" ]; then
    printf '{\n'
    printf '  "released": true,\n'
    printf '  "previousVersion": '; zr_json_string "$ZR_PREVIOUS_VERSION"; printf ',\n'
    printf '  "nextVersion": '; zr_json_string "$ZR_NEXT_VERSION"; printf ',\n'
    printf '  "previousTag": '; zr_json_string "$ZR_PREVIOUS_TAG"; printf ',\n'
    printf '  "nextTag": '; zr_json_string "$ZR_NEXT_TAG"; printf ',\n'
    printf '  "bump": '; zr_json_string "$ZR_BUMP"; printf ',\n'
    printf '  "channel": '; zr_json_string "$ZR_CHANNEL"; printf ',\n'
    printf '  "dryRun": '; zr_json_bool "$ZR_DRY_RUN"; printf ',\n'
    printf '  "currentBranch": '; zr_json_string "$ZR_CURRENT_BRANCH"; printf ',\n'
    printf '  "commits": {\n'
    printf '    "total": %s,\n' "$ZR_COMMIT_TOTAL"
    printf '    "features": %s,\n' "$ZR_COMMIT_FEATURES"
    printf '    "fixes": %s,\n' "$ZR_COMMIT_FIXES"
    printf '    "performance": %s,\n' "$ZR_COMMIT_PERFORMANCE"
    printf '    "breaking": %s,\n' "$ZR_COMMIT_BREAKING"
    printf '    "other": %s\n' "$ZR_COMMIT_OTHER"
    printf '  },\n'
    printf '  "plugins": {\n'
    printf '    "verify": '; zr_plugin_array_json_for_hook "verify"; printf ',\n'
    printf '    "generateNotes": '; zr_plugin_array_json_for_hook "generate-notes"; printf ',\n'
    printf '    "prepare": '; zr_plugin_array_json_for_hook "prepare"; printf ',\n'
    printf '    "publish": '; zr_plugin_array_json_for_hook "publish"; printf ',\n'
    printf '    "notify": '; zr_plugin_array_json_for_hook "notify"; printf '\n'
    printf '  }\n'
    printf '}\n'
  else
    printf '{\n'
    printf '  "released": false,\n'
    printf '  "reason": '; zr_json_string "$ZR_REASON"; printf ',\n'
    printf '  "previousVersion": '; zr_json_string "$ZR_PREVIOUS_VERSION"; printf ',\n'
    printf '  "previousTag": '; zr_json_string "$ZR_PREVIOUS_TAG"; printf ',\n'
    printf '  "dryRun": '; zr_json_bool "$ZR_DRY_RUN"; printf ',\n'
    printf '  "currentBranch": '; zr_json_string "$ZR_CURRENT_BRANCH"; printf '\n'
    printf '}\n'
  fi
}

zr_print_dry_run_text() {
  printf 'zero-release dry run\n'
  printf 'Branch: %s (%s)\n' "$ZR_CURRENT_BRANCH" "$ZR_BRANCH_KIND"
  printf 'Previous version: %s\n' "$ZR_PREVIOUS_VERSION"
  printf 'Previous tag: %s\n' "${ZR_PREVIOUS_TAG:-none}"
  printf 'Bump: %s\n' "$ZR_BUMP"
  printf 'Next version: %s\n' "$ZR_NEXT_VERSION"
  printf 'Next tag: %s\n' "$ZR_NEXT_TAG"
  printf 'Channel: %s\n' "$ZR_CHANNEL"
  printf 'Plugins verify: '; zr_hook_plugins "verify" | awk 'BEGIN { first = 1 } { if (!first) printf ", "; printf "%s", $0; first = 0 } END { print "" }'
  printf 'Plugins generate-notes: '; zr_hook_plugins "generate-notes" | awk 'BEGIN { first = 1 } { if (!first) printf ", "; printf "%s", $0; first = 0 } END { print "" }'
  printf 'Plugins prepare: '; zr_hook_plugins "prepare" | awk 'BEGIN { first = 1 } { if (!first) printf ", "; printf "%s", $0; first = 0 } END { print "" }'
  printf 'Plugins notify: '; zr_hook_plugins "notify" | awk 'BEGIN { first = 1 } { if (!first) printf ", "; printf "%s", $0; first = 0 } END { print "" }'
  printf 'Files that would change:\n'
  if zr_plugin_enabled "changelog"; then
    printf '  - %s\n' "$ZR_CHANGELOG_FILE"
  fi
  if zr_plugin_enabled "package-json"; then
    printf '  - %s\n' "$ZR_PACKAGE_JSON"
  fi
  printf 'Would create tag: %s\n' "$([ "$ZR_NO_TAG" = "true" ] && printf 'no' || printf 'yes')"
  printf 'Would push: %s\n' "$([ "$ZR_NO_PUSH" = "true" ] && printf 'no' || printf 'yes')"
  printf 'Network notifications: skipped\n'
  printf '\nRelease notes preview:\n'
  awk '{ print }' "$ZR_NOTES_FILE"
}

zr_print_release_text() {
  if [ "$ZR_RELEASED" != "true" ]; then
    printf '%s\n' "$ZR_REASON"
    return 0
  fi

  if [ "$ZR_DRY_RUN" = "true" ]; then
    zr_print_dry_run_text
  else
    printf 'Released %s (%s)\n' "$ZR_NEXT_TAG" "$ZR_CHANNEL"
  fi
}

zr_doctor_text_bool() {
  local label="$1"
  local value="$2"
  printf '%-44s %s\n' "$label" "$value"
}

zr_doctor_json_check() {
  local name="$1"
  local ok="$2"
  local detail="$3"
  local comma="${4-,}"

  printf '    "%s": { "ok": ' "$name"
  zr_json_bool "$ok"
  printf ', "detail": '
  zr_json_string "$detail"
  printf ' }%s\n' "$comma"
}

zr_doctor_network_plugins() {
  local plugin path output

  ZR_DOCTOR_NETWORK_OK="true"
  ZR_DOCTOR_NETWORK_DETAIL=""

  while IFS= read -r plugin; do
    [ -n "$plugin" ] || continue
    if ! zr_plugin_enabled "$plugin"; then
      continue
    fi
    if ! zr_plugin_is_network "$plugin"; then
      continue
    fi

    path="$ZERO_RELEASE_ROOT_DIR/plugins/$plugin/plugin"
    if output="$("$path" doctor 2>&1)"; then
      :
    else
      ZR_DOCTOR_NETWORK_OK="false"
      if [ -n "$ZR_DOCTOR_NETWORK_DETAIL" ]; then
        ZR_DOCTOR_NETWORK_DETAIL="${ZR_DOCTOR_NETWORK_DETAIL}; "
      fi
      ZR_DOCTOR_NETWORK_DETAIL="${ZR_DOCTOR_NETWORK_DETAIL}${output}"
    fi
  done < <(zr_hook_order "notify")

  if [ -z "$ZR_DOCTOR_NETWORK_DETAIL" ]; then
    ZR_DOCTOR_NETWORK_DETAIL="ok"
  fi
}

zr_doctor() {
  local bash_ok="true" git_ok="false" repo_ok="false" tags_ok="false" branch_ok="false"
  local allowed_ok="false" remote_ok="false" provider_ok="false" plugins_ok="true"
  local network_ok="true" pr_safety="$ZR_GITHUB_PR_SAFETY" dry_default="false"
  local branch repo provider tags plugin detail

  command -v git >/dev/null 2>&1 && git_ok="true"
  git rev-parse --is-inside-work-tree >/dev/null 2>&1 && repo_ok="true"
  if [ "$repo_ok" = "true" ]; then
    tags="$(git tag --list 2>/dev/null | awk 'END { print NR }')"
    [ "${tags:-0}" -gt 0 ] && tags_ok="true"
    branch="$(zr_current_branch)"
    if [ -n "$branch" ] && [ "$branch" != "HEAD" ]; then
      branch_ok="true"
      ZR_CURRENT_BRANCH="$branch"
      if zr_validate_branch_name "$branch" && zr_classify_branch "$branch"; then
        allowed_ok="true"
      fi
    fi
    repo="$(zr_get_repository_url 2>/dev/null || true)"
    if [ -n "$repo" ]; then
      remote_ok="true"
      provider="$(zr_detect_provider "$repo")"
      [ "$provider" != "unknown" ] && provider_ok="true"
    else
      provider="unknown"
    fi
  else
    branch=""
    repo=""
    provider="unknown"
  fi

  if [ "$ZR_PLUGINS_VALID" != "true" ]; then
    plugins_ok="false"
  fi

  zr_doctor_network_plugins
  network_ok="$ZR_DOCTOR_NETWORK_OK"

  if [ "${GITHUB_EVENT_NAME:-}" = "pull_request" ] || [ "${GITHUB_HEAD_REPO_FORK:-}" = "true" ]; then
    pr_safety="true"
  fi

  if [ "${GITHUB_EVENT_NAME:-}" = "pull_request" ]; then
    dry_default="true"
  fi

  if [ "$ZR_JSON" = "true" ]; then
    printf '{\n'
    printf '  "checks": {\n'
    zr_doctor_json_check "bash" "$bash_ok" "${BASH_VERSION:-available}"
    zr_doctor_json_check "git" "$git_ok" "$(command -v git 2>/dev/null || true)"
    zr_doctor_json_check "gitRepository" "$repo_ok" "$PWD"
    zr_doctor_json_check "tagsAvailable" "$tags_ok" "${tags:-0} tag(s)"
    zr_doctor_json_check "currentBranch" "$branch_ok" "$branch"
    zr_doctor_json_check "branchAllowed" "$allowed_ok" "$branch"
    zr_doctor_json_check "repositoryRemote" "$remote_ok" "$repo"
    zr_doctor_json_check "repositoryProvider" "$provider_ok" "$provider"
    zr_doctor_json_check "pluginsKnown" "$plugins_ok" "$ZR_PLUGINS"
    zr_doctor_json_check "networkPluginRequirements" "$network_ok" "$ZR_DOCTOR_NETWORK_DETAIL"
    zr_doctor_json_check "githubPullRequestSafety" "$pr_safety" "${GITHUB_EVENT_NAME:-}"
    zr_doctor_json_check "defaultDryRun" "$dry_default" "${GITHUB_EVENT_NAME:-}" ""
    printf '  }\n'
    printf '}\n'
  else
    printf 'zero-release doctor\n'
    zr_doctor_text_bool "bash" "$bash_ok"
    zr_doctor_text_bool "git" "$git_ok"
    zr_doctor_text_bool "git repository" "$repo_ok"
    zr_doctor_text_bool "tags available" "$tags_ok"
    zr_doctor_text_bool "current branch" "$branch_ok ${branch:-}"
    zr_doctor_text_bool "branch allowed" "$allowed_ok"
    zr_doctor_text_bool "repository remote" "$remote_ok ${repo:-}"
    zr_doctor_text_bool "repository provider" "$provider_ok $provider"
    zr_doctor_text_bool "plugins known" "$plugins_ok"
    zr_doctor_text_bool "network plugin requirements" "$network_ok $ZR_DOCTOR_NETWORK_DETAIL"
    zr_doctor_text_bool "GitHub PR safety mode" "$pr_safety"
    zr_doctor_text_bool "default dry-run" "$dry_default"
  fi
}

zr_main() {
  zr_parse_args "$@"
  zr_setup

  if [ "$ZR_COMMAND" = "doctor" ]; then
    zr_export_context
    zr_doctor
    return 0
  fi

  zr_analyze_release
  zr_export_context

  if [ "$ZR_COMMAND" = "analyze" ]; then
    zr_write_github_outputs
    if [ "$ZR_JSON" = "true" ]; then
      zr_release_json
    elif [ "$ZR_RELEASED" = "true" ]; then
      printf '%s release: %s -> %s (%s)\n' "$ZR_BUMP" "$ZR_PREVIOUS_VERSION" "$ZR_NEXT_VERSION" "$ZR_CHANNEL"
    else
      printf '%s\n' "$ZR_REASON"
    fi
    return 0
  fi

  zr_run_hook "verify" || return $?
  zr_verify_release || return $?

  if [ "$ZR_RELEASED" = "true" ]; then
    zr_generate_notes || return $?
    zr_export_context
    zr_prepare_release || return $?
    zr_publish_release || return $?
    zr_notify_release || return $?
    zr_run_hook "success" || return $?
  fi

  zr_write_github_outputs

  if [ "$ZR_JSON" = "true" ]; then
    zr_release_json
  else
    zr_print_release_text
  fi
}

zr_main "$@" || {
  status="$?"
  ZR_RELEASED="false"
  zr_export_context || true
  zr_run_hook "fail" >/dev/null 2>&1 || true
  exit "$status"
}
